# Copy this file to .env and fill in your values. .env is gitignored.
#
# FRIDAY uses the `claude` CLI (Claude Code) as its brain,
# authenticated against your Claude Pro/Max subscription — NOT a separate
# API key. Before running:
#   1. Install Claude Code:  npm install -g @anthropic-ai/claude-code
#   2. Log in:                claude login
#
# Do NOT set ANTHROPIC_API_KEY unless you specifically want pay-as-you-go
# API billing — if it's set, the claude CLI uses it instead of your
# subscription.

# ---- Brain -----------------------------------------------------------------
# Path to the claude binary, if not on PATH.
FRIDAY_CLAUDE_BIN=claude
# Model the assistant asks the claude CLI to use.
FRIDAY_MODEL=claude-sonnet-5

# ---- Obsidian --------------------------------------------------------------
# Absolute path to your Obsidian vault folder (the folder that contains your
# .md notes). We read/write it directly — no plugin needed. Defaults to
# ~/ObsidianVault if left blank.
OBSIDIAN_VAULT=
# Subfolder (inside the vault) where daily notes live. Match your Obsidian
# "Daily notes" setting. Blank = vault root.
OBSIDIAN_DAILY_NOTES_DIR=Daily

# ---- Locale ----------------------------------------------------------------
# IANA timezone used when creating calendar events / meetings, e.g.
# "Asia/Kolkata", "America/New_York". Defaults to UTC.
FRIDAY_TIMEZONE=UTC

# ---- Google (Gmail + Calendar + Meet) --------------------------------------
# 1. Google Cloud Console → enable Gmail API + Google Calendar API.
# 2. Create an OAuth client ID (type: Desktop app), download the JSON.
# 3. Point GOOGLE_CREDENTIALS_FILE at it (or drop it at the default path).
# 4. Run:  friday auth-google   (one-time browser consent).
# Defaults live under ~/.friday/ if left blank.
GOOGLE_CREDENTIALS_FILE=
GOOGLE_TOKEN_FILE=

# ---- Zoom (optional — only if you create Zoom meetings) --------------------
# marketplace.zoom.us → create a "Server-to-Server OAuth" app with the
# meeting:write scope, then copy these three values.
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
